{
	"name": "@cloudcannon/cli",
	"type": "module",
	"version": "0.0.0",
	"description": "Command line interface for the CloudCannon CMS.",
	"keywords": [],
	"homepage": "https://github.com/CloudCannon/cli#readme",
	"repository": {
		"type": "git",
		"url": "https://github.com/CloudCannon/cli.git"
	},
	"bugs": {
		"url": "https://github.com/CloudCannon/cli/issues",
		"email": "support@cloudcannon.com"
	},
	"main": "dist/index.js",
	"bin": {
		"cloudcannon": "./dist/index.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc",
		"test": "node --experimental-strip-types --test",
		"test:watch": "node --experimental-strip-types --test --watch",
		"test:coverage": "node --test --experimental-test-coverage --test-reporter=lcov --test-reporter-destination=lcov.info",
		"lint": "biome check && tsc --noEmit",
		"lint:fix": "biome check --fix"
	},
	"author": "CloudCannon <support@cloudcannon.com>",
	"devDependencies": {
		"@biomejs/biome": "2.4.11",
		"@cloudcannon/configuration-types": "0.0.54",
		"@types/node": "25.6.0",
		"typescript": "6.0.2"
	},
	"license": "MIT",
	"dependencies": {
		"@clack/prompts": "1.2.0",
		"@cloudcannon/gadget": "0.0.29",
		"citty": "0.2.2",
		"yaml": "2.8.3"
	}
}
